# ==========================================================================
# ASCENSION SYSTEM - Variaveis de ambiente
# Copie este arquivo para ".env" e preencha os valores.
# O arquivo .env e carregado automaticamente no boot (dotenv/config).
# ==========================================================================

# --- Servidor ---
# Porta preferida do servidor (opcional, padrao 3000).
PORT=3000

# --- Login local ---
# Senha unica que libera o acesso ao app (tela de login).
APP_PASSWORD=troque-esta-senha

# Nome e email do dono, exibidos no app.
APP_OWNER_NAME=Monarch
APP_OWNER_EMAIL=

# --- Sessao / JWT ---
# Segredo usado para assinar os cookies de sessao (HS256). Use um valor longo e aleatorio.
JWT_SECRET=troque-por-um-segredo-longo-e-aleatorio

# --- Banco de dados (SQLite) - OPCIONAL ---
# O app usa um arquivo SQLite local, criado automaticamente no primeiro boot.
# Padrao: data/ascension.db (nenhuma configuracao necessaria).
# Defina abaixo apenas se quiser mudar o caminho do arquivo.
# DATABASE_URL=data/ascension.db
